APP_NAME=TIPTAP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tiptapafrica.co.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=taptap
DB_USERNAME=root
DB_PASSWORD=TiptapTz@2026!

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@tiptapafrica.co.tz"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp (Meta) – TZ phone number
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v20.0

# Laravel → TZ bot VPS (wa-notify)
WHATSAPP_BOT_NOTIFY_URL=https://wa-notify.tiptapafrica.co.tz/notify
WHATSAPP_BOT_NOTIFY_SECRET=
WHATSAPP_BOT_NOTIFY_TIMEOUT=60
WHATSAPP_BILL_IMAGE_BASE_URL=https://tiptapafrica.co.tz

# Sanctum token for bot API (/api/bot/*)
BOT_TOKEN=

# TipTap market (Tanzania)
TIPTAP_MARKET=tz
TIPTAP_CURRENCY_SYMBOL=Tsh
TIPTAP_CURRENCY_CODE=TZS
TIPTAP_COUNTRY_CODE=255
TIPTAP_PAYMENT_GATEWAY=Selcom

ADMIN_LIVE_POLL_SECONDS=30
DOCKER_CONTROL_ENABLED=true
DOCKER_LARAVEL_WORK_DIR=/var/www/html
# Bot VPS (SSH from app container — key lives in storage volume)
# DOCKER_BOT_SSH_HOST=178.62.61.85
# DOCKER_BOT_SSH_KEY=/var/www/html/storage/docker-ssh/docker_control
# DOCKER_BOT_WORK_DIR=/opt/titap-bot/tiptopbot
