APP_NAME=TIPTAP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=taptap
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# TipTap market (tz = Tanzania, za = South Africa)
TIPTAP_MARKET=tz
TIPTAP_CURRENCY_SYMBOL=Tsh
TIPTAP_CURRENCY_CODE=TZS
TIPTAP_COUNTRY_CODE=255
TIPTAP_PAYMENT_GATEWAY=Selcom

# Sanctum bearer token for WhatsApp bot → /api/bot/* (generate at /admin/bots)
BOT_TOKEN=
# Clear WhatsApp bot restaurant sessions after this many hours without a message (default 12)
BOT_SESSION_IDLE_HOURS=12

# Admin → /admin/infrastructure/docker (super_admin only)
DOCKER_CONTROL_ENABLED=false
DOCKER_CONTROL_POLL_SECONDS=15
# Laravel stack: SSH to VPS (recommended when PHP runs inside a container)
# DOCKER_LARAVEL_SSH_HOST=164.92.242.245
# DOCKER_LARAVEL_SSH_KEY=/root/.ssh/id_ed25519
# DOCKER_LARAVEL_WORK_DIR=/root/TIPTAP
# Bot VPS (separate server)
# DOCKER_BOT_SSH_HOST=178.62.61.85
# DOCKER_BOT_SSH_KEY=/root/.ssh/id_ed25519
# DOCKER_BOT_WORK_DIR=/opt/titap-bot/tiptopbot

ADMIN_LIVE_POLL_SECONDS=30

# Waiter feedback: comments appear on waiter platform after this many minutes (anonymous).
FEEDBACK_VISIBLE_AFTER_MINUTES=60

# WhatsApp bot bill push (Laravel -> Node notify HTTP). Use HTTPS on port 443 in production
# when web hosting blocks outbound connections to raw :3001 (see tiptopbot/deploy/nginx-wa-notify.example.conf).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v20.0

WHATSAPP_BOT_NOTIFY_URL=
WHATSAPP_BOT_NOTIFY_SECRET=
WHATSAPP_BOT_NOTIFY_TIMEOUT=60

# If the bill PNG URL must include /public (same as your /public/api/bot), set this so the bot can fetch it.
# Bill links look like: {BASE}/bill-image/{id}/{64-char-hex-signature} (path, not ?signature=, for WAF-friendly fetching).
# WHATSAPP_BILL_IMAGE_BASE_URL=https://tiptapafrica.co.tz/public

# Landing page — offices & social (TipTap Africa)
TIPTAP_WHATSAPP_BOT_NUMBER=255791070771
TIPTAP_WHATSAPP_URL=https://wa.me/255791070771
# TIPTAP_SOCIAL_FACEBOOK=
# TIPTAP_SOCIAL_INSTAGRAM=
# TIPTAP_SOCIAL_X=
# TIPTAP_SOCIAL_LINKEDIN=
# TIPTAP_SOCIAL_TIKTOK=
# TIPTAP_SOCIAL_YOUTUBE=
